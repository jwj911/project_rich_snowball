# ============================================
# 期货交流社区 — 环境变量配置模板
# 复制为 .env 后填入真实值
# ============================================

# --------------------------------------------
# 数据库配置（二选一）
# --------------------------------------------

# 方案 A：SQLite（零配置，适合开发/个人使用）
# DATABASE_URL=sqlite:///./futures_community.db

# 方案 B：PostgreSQL（需先 docker-compose up -d postgres）
DATABASE_URL=postgresql://futures:futures123@localhost:5432/futures_community

# --------------------------------------------
# JWT / 安全（⚠️ 生产环境必须修改！）
# --------------------------------------------
SECRET_KEY=your-super-secret-key-change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --------------------------------------------
# CORS 配置
# --------------------------------------------
# 推荐使用 CORS_ORIGINS；ALLOW_ORIGINS 作为旧兼容变量仍可使用
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3200,http://127.0.0.1:3200

# --------------------------------------------
# Redis 缓存（可选，留空则使用内存缓存）
# --------------------------------------------
# REDIS_URL=redis://localhost:6379/0

# --------------------------------------------
# 数据采集配置
# --------------------------------------------
# 数据源选择：mock / tushare / akshare
DATA_SOURCE=mock
# Tushare Pro Token（使用 tushare 数据源时必填）
TUSHARE_TOKEN=your-tushare-token-here
# 实时行情刷新间隔（秒）
REALTIME_INTERVAL=30
# 是否启用定时采集任务（1=启用，0=禁用）
ENABLE_SCHEDULER=1

# --------------------------------------------
# 运行环境（development / production）
# --------------------------------------------
# development：启用 Swagger UI、自动插入 mock 数据
# production：关闭 Swagger UI、不插入 mock 数据
ENV=development

# --------------------------------------------
# API 服务监听地址
# --------------------------------------------
# Windows 上 8000 端口可能位于系统 TCP 排除端口段内；默认使用 127.0.0.1:8200，
# 与前端 NEXT_PUBLIC_API_BASE=http://127.0.0.1:8200 保持一致。
HOST=127.0.0.1
PORT=8200
